{
  "domain": "meltem_ventilation",
  "name": "Meltem Modbus",
  "codeowners": [
    "@manndreas"
  ],
  "config_flow": true,
  "documentation": "https://github.com/manndreas/meltem-ha#readme",
  "integration_type": "hub",
  "iot_class": "local_polling",
  "issue_tracker": "https://github.com/manndreas/meltem-ha/issues",
  "loggers": [
    "custom_components.meltem_ventilation",
    "pymodbus"
  ],
  "requirements": [
    "pymodbus>=3.6.9,<4.0.0"
  ],
  "single_config_entry": true,
  "usb": [
    {
      "description": "*modbus*",
      "manufacturer": "*honeywell*",
      "pid": "010A",
      "vid": "10AC"
    }
  ],
  "version": "2.0.0"
}
